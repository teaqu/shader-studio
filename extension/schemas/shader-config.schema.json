{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Shader Studio Configuration",
  "description": "Configuration file for Shader Studio extension (.sha.json)",
  "type": "object",
  "required": ["version", "passes"],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0",
      "description": "Configuration version"
    },
    "script": {
      "type": "string",
      "description": "Path to a JavaScript file that exports a uniforms(ctx) function for custom uniforms"
    },
    "scriptMaxPollingFps": {
      "type": "number",
      "description": "Maximum polling rate for the script uniforms function (in evaluations per second). Default: 30",
      "default": 30,
      "minimum": 1,
      "maximum": 120
    },
    "passes": {
      "$ref": "#/definitions/ShaderPasses"
    }
  },
  "additionalProperties": false,
  "definitions": {
    "ShaderPasses": {
      "type": "object",
      "description": "Shader passes configuration",
      "required": ["Image"],
      "properties": {
        "Image": {
          "$ref": "#/definitions/ImagePass"
        },
        "common": {
          "$ref": "#/definitions/BufferPass"
        }
      },
      "patternProperties": {
        "^(?!Image$|common$)[a-zA-Z_][a-zA-Z0-9_]*$": {
          "$ref": "#/definitions/BufferPass"
        }
      },
      "additionalProperties": false
    },
    "ImagePass": {
      "type": "object",
      "description": "Main image pass configuration",
      "properties": {
        "inputs": {
          "$ref": "#/definitions/PassInputs"
        },
        "resolution": {
          "$ref": "#/definitions/ImageResolution"
        }
      },
      "additionalProperties": false
    },
    "BufferPass": {
      "type": "object",
      "description": "Buffer pass configuration",
      "required": ["path"],
      "properties": {
        "path": {
          "type": "string",
          "description": "Path to the buffer GLSL file (relative, absolute, or @ for workspace root)"
        },
        "inputs": {
          "$ref": "#/definitions/PassInputs"
        },
        "resolution": {
          "$ref": "#/definitions/BufferResolution"
        }
      },
      "additionalProperties": false
    },
    "PositiveNumber": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "ImageResolution": {
      "type": "object",
      "description": "Image pass resolution override",
      "oneOf": [
        {
          "properties": {
            "scale": {
              "$ref": "#/definitions/PositiveNumber",
              "description": "Render scale multiplier"
            },
            "aspectRatio": {
              "type": "string",
              "enum": ["16:9", "4:3", "1:1", "fill", "auto"],
              "description": "Canvas aspect ratio mode"
            }
          },
          "additionalProperties": false
        },
        {
          "required": ["width", "height"],
          "properties": {
            "scale": {
              "$ref": "#/definitions/PositiveNumber",
              "description": "Render scale multiplier"
            },
            "width": {
              "$ref": "#/definitions/PositiveNumber",
              "description": "Base render width in pixels"
            },
            "height": {
              "$ref": "#/definitions/PositiveNumber",
              "description": "Base render height in pixels"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "BufferResolution": {
      "type": "object",
      "description": "Buffer pass resolution override",
      "oneOf": [
        {
          "required": ["width", "height"],
          "properties": {
            "width": {
              "$ref": "#/definitions/PositiveNumber"
            },
            "height": {
              "$ref": "#/definitions/PositiveNumber"
            }
          },
          "additionalProperties": false
        },
        {
          "required": ["scale"],
          "properties": {
            "scale": {
              "$ref": "#/definitions/PositiveNumber",
              "description": "Multiplier relative to the Image pass resolution"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "PassInputs": {
      "type": "object",
      "description": "Input channels for a pass. Keys can be iChannel0-iChannel15 or custom GLSL-valid identifiers.",
      "patternProperties": {
        "^[a-zA-Z_][a-zA-Z0-9_]*$": {
          "$ref": "#/definitions/ConfigInput"
        }
      },
      "additionalProperties": false,
      "maxProperties": 16
    },
    "ConfigInput": {
      "type": "object",
      "required": ["type"],
      "oneOf": [
        {
          "type": "object",
          "required": ["type", "source"],
          "properties": {
            "type": {
              "const": "buffer"
            },
            "source": {
              "type": "string",
              "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
              "description": "Source buffer name (any valid GLSL identifier)"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "path"],
          "properties": {
            "type": {
              "const": "texture"
            },
            "path": {
              "type": "string",
              "description": "Path to texture file"
            },
            "filter": {
              "type": "string",
              "enum": ["linear", "nearest", "mipmap"],
              "description": "Texture filtering mode"
            },
            "wrap": {
              "type": "string",
              "enum": ["repeat", "clamp"],
              "description": "Texture wrap mode"
            },
            "vflip": {
              "type": "boolean",
              "description": "Whether to flip texture vertically"
            },
            "grayscale": {
              "type": "boolean",
              "description": "Load texture as single channel (R8) instead of RGBA"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "path"],
          "properties": {
            "type": {
              "const": "video"
            },
            "path": {
              "type": "string",
              "description": "Path to video file"
            },
            "filter": {
              "type": "string",
              "enum": ["linear", "nearest", "mipmap"],
              "description": "Video filtering mode"
            },
            "wrap": {
              "type": "string",
              "enum": ["repeat", "clamp"],
              "description": "Video wrap mode"
            },
            "vflip": {
              "type": "boolean",
              "description": "Whether to flip video vertically"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "path"],
          "properties": {
            "type": {
              "const": "cubemap"
            },
            "path": {
              "type": "string",
              "description": "Path to cubemap cross-pattern PNG file"
            },
            "filter": {
              "type": "string",
              "enum": ["linear", "nearest", "mipmap"],
              "description": "Cubemap filtering mode"
            },
            "wrap": {
              "type": "string",
              "enum": ["repeat", "clamp"],
              "description": "Cubemap wrap mode"
            },
            "vflip": {
              "type": "boolean",
              "description": "Whether to flip cubemap faces vertically"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type"],
          "properties": {
            "type": {
              "const": "keyboard"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "path"],
          "properties": {
            "type": {
              "const": "audio"
            },
            "path": {
              "type": "string",
              "description": "Path to audio file"
            },
            "startTime": {
              "type": "number",
              "minimum": 0,
              "description": "Loop region start time in seconds"
            },
            "endTime": {
              "type": "number",
              "minimum": 0,
              "description": "Loop region end time in seconds"
            }
          },
          "additionalProperties": false
        }
      ]
    }
  }
}
