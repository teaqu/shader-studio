{
  "name": "shader-studio-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "copy-to-extension": "rimraf ../extension/ui-dist && cpx \"dist/**/*\" ../extension/ui-dist",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/svelte": "^5.2.8",
    "@testing-library/user-event": "^14.5.2",
    "svelte": "^5.28.1",
    "svelte-check": "^4.0.8"
  },
  "dependencies": {
    "@shader-studio/glsl-debug": "*",
    "@shader-studio/monaco": "*",
    "@shader-studio/rendering": "*",
    "@shader-studio/types": "*",
    "@vscode/codicons": "^0.0.45",
    "dockview-core": "^5.0.0",
    "gifski-wasm": "^2.2.0",
    "monaco-editor": "^0.55.1",
    "monaco-vim": "^0.4.4",
    "mp4-muxer": "^5.2.2",
    "webm-muxer": "^5.1.4"
  }
}
